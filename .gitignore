# =========================
/runs/
/results/
/experiments/
/checkpoints/
/models/
/artifacts/

# Generated data, but keep examples if needed
data/generated/
data/cache/
data/raw/
!data/examples/
!data/examples/**

# Generated reports, but keep documentation sources
reports/generated/
reports/htmlcov/
!reports/examples/
!reports/examples/**

