# Local databases
# =========================
*.db
*.sqlite
*.sqlite3
*.db-journal
*.sqlite-journal
*.sqlite3-journal

# Keep folder structure, but ignore generated database files
data/*.db
data/*.sqlite
data/*.sqlite3
!data/.gitkeep
!data/README.md

